   "source": [
    "# DataFrame with data\n",
    "import pandas as pd\n",
    "data = {'A': [1, 2, 3], 'B': ['a', 'b', 'c']}\n",
    "df = pd.DataFrame(data)\n",
    "\n",
    "# Check if the DataFrame is truthy or falsy\n",
    "is_truthy = df.bool()\n",
    "print(is_truthy)  # Output: True"
   ]
